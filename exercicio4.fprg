    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <output expression="&quot;Digite um n&#250;mero&quot;" newline="True"/>
            <declare name="numero" type="Real" array="False" size=""/>
            <input variable="numero"/>
            <if expression="numero = 0">
                <then>
                    <output expression="&quot;N&#250;mero &#233; 0&quot;" newline="True"/>
                </then>
                <else>
                    <if expression="numero &gt; 0">
                        <then>
                            <output expression="&quot;N&#250;mero positivo!&quot;" newline="True"/>
                        </then>
                        <else>
                            <output expression="&quot;N&#250;mero negativo!&quot;" newline="True"/>
                        </else>
                    </if>
                </else>
            </if>
        </body>
    </function>
</flowgorithm>
